[Unit]
Description=gunicorn daemon
After=network.target

[Service]
User=root
Group=www-data
WorkingDirectory={{ app_folder }}
ExecStart={{virtualenv_dir}}/bin/gunicorn --access-logfile - --workers 3 --bind unix:{{ app_folder }}/MyApp.sock MyApp.wsgi:application

[Install]
WantedBy=multi-user.target
